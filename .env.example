# Copy this file to .env, then fill in the values needed for your test.
# Keep .env local. Do not commit real keys.

# Speech / Voice Live resource
AZURE_VOICELIVE_ENDPOINT=https://<your-speech-resource>.cognitiveservices.azure.cn/
AZURE_VOICELIVE_API_KEY=<your-speech-key>
AZURE_VOICELIVE_BYOM_MODE=byom-chat-completion
AZURE_VOICELIVE_VOICE=zh-CN-XiaoxiaoMultilingualNeural
AZURE_VOICELIVE_VOICE_RATE=10%
AZURE_VOICELIVE_INSTRUCTIONS=你是一个自然、简洁、适合语音对话的中文助手。优先使用用户提问的语言回答；用户使用中文时请直接用中文回答。不要在每轮回复开头固定说 Hello、你好或其他寒暄，除非用户主动问候。回答要适合语音播报，避免 Markdown。

# Baseline / Foundry-style endpoint key. Used by the Baseline provider.
BYOM_API_KEY=<your-baseline-or-foundry-key>

# Provider-specific keys. Fill only the models you want to test.
BYOM_DOUBAO_API_KEY=<your-ark-key>
BYOM_DEEPSEEK_API_KEY=<your-deepseek-or-foundry-token>
BYOM_KIMI_API_KEY=<your-kimi-or-foundry-token>
BYOM_MINIMAX_API_KEY=<your-minimax-key>

# Optional provider-specific overrides. Leave blank to use the built-in presets.
# BYOM_DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
# BYOM_DOUBAO_MODEL_TYPE=doubao-seed-2-0-lite-260428
# BYOM_DEEPSEEK_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/openai/v1/
# BYOM_DEEPSEEK_MODEL_TYPE=DeepSeek-V4-Flash
# BYOM_KIMI_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/openai/v1/
# BYOM_KIMI_MODEL_TYPE=Kimi-K2.6
# BYOM_MINIMAX_ENDPOINT=https://api.minimaxi.com/v1
# BYOM_MINIMAX_MODEL_TYPE=MiniMax-M2.7
